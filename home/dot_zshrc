ZOXIDE_CMD_OVERRIDE="cd"
source '/usr/share/zsh-antidote/antidote.zsh'
antidote load

command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"
command -v atuin >/dev/null 2>&1 && eval "$(atuin init zsh --disable-up-arrow)"
command -v scw >/dev/null 2>&1 && eval "$(scw autocomplete script shell=zsh)"

zstyle ':omz:plugins:eza' 'git-status' yes
zstyle ':omz:plugins:eza' 'icons' yes

# Alias definitions.
setopt complete_aliases

# archlinux tools configuration / aliases
export ARCHWEB_USERNAME="LeGmask"

alias signoff='ARCHWEB_PASSWORD="$(secret-tool lookup app archweb)" signoff'

# local bin
export PATH=$PATH:$HOME/.local/bin

# go configuration
export GOPATH=$HOME/.go
export PATH=$PATH:$GOPATH/bin

# ruby configuration
if [ command -v gem >/dev/null 2>&1 ]; then
    export GEM_HOME="$(gem env user_gemhome)"
    export PATH="$PATH:$GEM_HOME/bin"
fi

[ "$TERM" = "xterm-kitty" ] && [ -z "$SSH_CONNECTION" ] && alias ssh="kssh"
command -v codium >/dev/null 2>&1 && alias code="codium"
alias ls="eza --git --icons=auto"
alias lst="ls --tree"
alias ip="ip -c"
alias weechat="ssh -t serge docker attach weechat"

if command -v kubecolor >/dev/null 2>&1; then
    alias kubectl=kubecolor
    compdef kubecolor=kubectl
fi;

# pass 
export PASSWORD_STORE_DIR=$HOME/git/hpc-git.uni.lu/ULHPC/password-repo

# remote session
if [ -n "$SSH_CONNECTION" ]; then
	export SSH_AUTH_SOCK=$XDG_RUNTIME_DIR/gcr/ssh
fi;
