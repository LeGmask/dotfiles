source  ~/.mutt/config/bindings
source  ~/.mutt/config/colors
source  ~/.mutt/config/evann@evann.dev

#
# Mutt behavior
set quit                = ask-yes
set menu_scroll         = yes
set mark_old            = no
set wait_key            = no

set sidebar_width           = 23
set sidebar_divider_char    = '│'
set sidebar_visible         = yes
set sidebar_sort_method     = unsorted
set sidebar_folder_indent   = yes
set sidebar_short_path      = yes
set sidebar_format          = '%B%* %?N?[%N]?'

set forward_attachments = yes

set sort            = threads
set sort_aux        = last-date
set strict_threads  = yes

set pager_index_lines   = 6
set pager_context       = 3
set pager_stop          = yes

set date_format     = "%c"
set index_format    = "%5C %Z %29D %-20.20F (%2e/%2E %4c) %s"
set simple_search   = "~f %s | ~C %s | ~s %s"

set ssl_force_tls = yes


#
# Cache
set header_cache        = ~/.cache/mutt/headers
set message_cachedir    = ~/.cache/mutt/messages


#
# Editor settings
set send_charset        = "utf-8"
set assumed_charset     = "iso-8859-1"
set editor              = "vim + -b -X -c 'set syntax=mail textwidth=72' +/^$ ++1"
set edit_hdrs


#
# Headers settings
ignore          *
unignore        From To X-Original-To Cc Bcc Reply-To Date Subject Message-ID User-Agent X-Mailer
unhdr_order     *
hdr_order       From: To: X-Original-To: Cc: Bcc: Reply-To: Date: Subject: Message-ID: User-Agent: X-Mailer:


#
# https://feeding.cloud.geek.nz/posts/handling-multiple-identitiesaccounts-in/
set     use_from
set     reverse_name
unset   reverse_realname


#
# Mail handling
set mailcap_path    = ~/.mutt/mailcap
mime_lookup         application/octet-stream
auto_view           text/html
alternative_order   text/plain text/enriched text/html


#
# Spam
set spam_separator=" | "
spam "X-Spam: Yes" "SA:Y"
