"custom/mode": {
    "format": "顖珄}",
    "rotate": ${r_deg},
    "exec": "echo ; echo 蟀煛 switch mode",
    "on-click": "~/.config/hyprdots/scripts/themeswitch.sh -n",
    "on-click-right": "~/.config/hyprdots/scripts/themeswitch.sh -p",
    "on-click-middle": "sleep 0.1 && ~/.config/hyprdots/scripts/themeselect.sh",
    "interval" : 86400, // once every day
    "tooltip": true
},
